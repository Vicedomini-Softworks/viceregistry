# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Public URL of the web UI (used for redirects, links in emails, etc.)
PUBLIC_URL=https://registry.example.com

# Hostname Docker clients use to pull/push — no scheme, no port
REGISTRY_PUBLIC_HOST=registry.example.com

# ── Database ──────────────────────────────────────────────────────────────────
# Password used by both the postgres container and the app connection string
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://viceregistry:CHANGE_ME@localhost:5432/viceregistry

# ── Web sessions ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME

# ── Registry connection ───────────────────────────────────────────────────────
# Internal URL — containers share network namespace inside the pod
REGISTRY_URL=http://localhost:5000

# Public URL where Docker clients fetch auth tokens — must be externally reachable
REGISTRY_AUTH_TOKEN_REALM=https://registry.example.com/api/auth/token
# Must match the `service` field in registry config.yml
REGISTRY_AUTH_TOKEN_SERVICE=registry.example.com

REGISTRY_TOKEN_ISSUER=viceregistry

# RSA-4096 keypair — generate with: npm run keys:generate
# Private key: place the PEM file at /etc/viceregistry/certs/token.key (mode 600).
#   The app container reads it from /certs/token.key (mounted read-only).
# Public key cert: deploy.sh writes this to /etc/viceregistry/certs/token.crt.
#   Newlines must be escaped as \n (the keys:generate script does this automatically)
REGISTRY_TOKEN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nCHANGE_ME\n-----END PUBLIC KEY-----"

# ── S3 Storage (app) ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1
S3_BUCKET=viceregistry-blobs
# Leave empty for native AWS S3; set to MinIO URL for self-hosted S3-compatible storage
S3_ENDPOINT_URL=

# ── S3 Storage (registry container) ──────────────────────────────────────────
# Must match the AWS_* values above — registry uses its own env var names
REGISTRY_STORAGE=s3
REGISTRY_STORAGE_S3_ACCESSKEY=CHANGE_ME
REGISTRY_STORAGE_S3_SECRETKEY=CHANGE_ME
REGISTRY_STORAGE_S3_BUCKET=viceregistry-blobs
REGISTRY_STORAGE_S3_REGION=us-east-1
# Leave empty for AWS; set to MinIO or compatible endpoint otherwise
REGISTRY_STORAGE_S3_REGIONENDPOINT=
REGISTRY_STORAGE_S3_FORCEPATHSTYLE=false
