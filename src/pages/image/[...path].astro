---
export const prerender = false
import AppLayout from "@/layouts/app.astro"
import ImageDetail from "@/components/registry/ImageDetail"
import Breadcrumb from "@/components/layout/Breadcrumb"
import { db } from "@/lib/db"
import { imageMetadata } from "@/lib/schema"
import { getManifest } from "@/lib/registry-client"
import { and, eq } from "drizzle-orm"

const rawPath = Astro.params.path ?? ""
const lastSlash = rawPath.lastIndexOf("/")
if (lastSlash === -1) return Astro.redirect("/dashboard")
const name = rawPath.slice(0, lastSlash)
const tag = rawPath.slice(lastSlash + 1)
if (!name || !tag) return Astro.redirect("/dashboard")

const registryHost = import.meta.env.REGISTRY_PUBLIC_HOST ?? "localhost:5000"

// Load metadata from PG (may be null if not yet synced)
const [pgMeta] = await db
  .select()
  .from(imageMetadata)
  .where(and(eq(imageMetadata.repository, name), eq(imageMetadata.tag, tag)))
  .limit(1)

// Always fetch live manifest for layer detail
let manifest: Record<string, unknown> = {}
let digest = pgMeta?.digest ?? ""

try {
  const res = await getManifest(name, tag)
  digest = res.headers.get("Docker-Content-Digest") ?? digest
  manifest = await res.json()
} catch {
  // fall through with empty manifest
}

const layers = (
  (manifest.layers ?? manifest.fsLayers ?? []) as Array<Record<string, unknown>>
).map((l) => ({
  digest: (l.digest ?? l.blobSum ?? "") as string,
  size: Number(l.size ?? 0),
  mediaType: (l.mediaType ?? "") as string,
}))
---

<AppLayout title={`${name}:${tag}`}>
  <div class="flex flex-col gap-6">
    <Breadcrumb
      client:load
      items={[
        { label: "Repositories", href: "/dashboard" },
        { label: name, href: `/repository/${name}` },
        { label: tag },
      ]}
    />
    <div>
      <h1 class="text-2xl font-semibold font-mono">
        {name}:<span class="text-primary">{tag}</span>
      </h1>
    </div>
    <ImageDetail
      client:load
      name={name}
      tag={tag}
      digest={digest}
      mediaType={(manifest.mediaType ?? "") as string}
      layers={layers}
      registryHost={registryHost}
      os={pgMeta?.os ?? undefined}
      architecture={pgMeta?.architecture ?? undefined}
      createdAt={pgMeta?.createdAt?.toISOString() ?? undefined}
    />
  </div>
</AppLayout>
