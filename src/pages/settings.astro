---
export const prerender = false
import AppLayout from "@/layouts/app.astro"
import { Button } from "@/components/ui/button"
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card"
import { Fingerprint, Trash2 } from "lucide-react"
import { db } from "@/lib/db"
import { webauthnCredentials, accessTokens, organizations, organizationMembers, repositories } from "@/lib/schema"
import { eq, desc } from "drizzle-orm"

const user = Astro.locals.user
if (!user) return Astro.redirect("/login")

const passkeys = await db
  .select({
    id: webauthnCredentials.id,
    deviceType: webauthnCredentials.deviceType,
    createdAt: webauthnCredentials.createdAt,
    lastUsedAt: webauthnCredentials.lastUsedAt,
  })
  .from(webauthnCredentials)
  .where(eq(webauthnCredentials.userId, user.sub))
  .orderBy(webauthnCredentials.createdAt)

const tokens = await db
  .select({
    id: accessTokens.id,
    name: accessTokens.name,
    tokenPreview: accessTokens.tokenPreview,
    expiresAt: accessTokens.expiresAt,
    createdAt: accessTokens.createdAt,
    organizationId: accessTokens.organizationId,
    repositoryName: accessTokens.repositoryName,
  })
  .from(accessTokens)
  .where(eq(accessTokens.userId, user.sub))
  .orderBy(desc(accessTokens.createdAt))

const userOrgs = await db
  .select({ id: organizations.id, name: organizations.name, slug: organizations.slug })
  .from(organizations)
  .innerJoin(organizationMembers, eq(organizations.id, organizationMembers.organizationId))
  .where(eq(organizationMembers.userId, user.sub))

const allRepos = await db.select({ name: repositories.name }).from(repositories)
---

<AppLayout title="Settings">
  <div class="flex flex-col gap-6 max-w-lg">
    <h1 class="text-2xl font-semibold">Settings</h1>

    <Card>
      <CardHeader>
        <CardTitle>Account</CardTitle>
        <CardDescription>Your account information</CardDescription>
      </CardHeader>
      <CardContent className="flex flex-col gap-3">
        <div class="flex flex-col gap-0.5">
          <span class="text-xs text-muted-foreground">Username</span>
          <span class="font-medium">{user.username}</span>
        </div>
        <div class="flex flex-col gap-0.5">
          <span class="text-xs text-muted-foreground">Roles</span>
          <span class="capitalize">{user.roles.join(", ")}</span>
        </div>
      </CardContent>
    </Card>

    <Card>
      <CardHeader>
        <CardTitle>Security</CardTitle>
        <CardDescription>Manage your passkeys</CardDescription>
      </CardHeader>
      <CardContent className="flex flex-col gap-4">
        {passkeys.length > 0 && (
          <div class="flex flex-col gap-2">
            {passkeys.map((pk) => (
              <div class="flex items-center justify-between p-3 border rounded-md">
                <div class="flex flex-col">
                  <span class="text-sm font-medium">Passkey ({pk.deviceType})</span>
                  <span class="text-xs text-muted-foreground">
                    Added: {new Date(pk.createdAt).toLocaleDateString()}
                  </span>
                </div>
                <Button
                  type="button"
                  variant="ghost"
                  size="icon"
                  className="text-destructive hover:bg-destructive/10 revoke-passkey-btn"
                  data-credential-id={pk.id}
                  title="Remove passkey"
                >
                  <Trash2 className="h-4 w-4" />
                </Button>
              </div>
            ))}
          </div>
        )}
        <Button id="register-passkey-btn" variant="outline">
          <Fingerprint className="mr-2 h-4 w-4" />
          Register New Passkey
        </Button>
      </CardContent>
    </Card>

    <Card>
      <CardHeader>
        <CardTitle>Update Profile</CardTitle>
        <CardDescription>Change your email or password</CardDescription>
      </CardHeader>
      <CardContent>
        <form id="settings-form" class="flex flex-col gap-4">
          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-sm font-medium">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              value={user.email}
              class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="currentPassword" class="text-sm font-medium">Current Password</label>
            <input
              id="currentPassword"
              name="currentPassword"
              type="password"
              class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="newPassword" class="text-sm font-medium">New Password</label>
            <input
              id="newPassword"
              name="newPassword"
              type="password"
              class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50"
            />
          </div>
          <Button type="submit" id="save-btn">Save Changes</Button>
        </form>
      </CardContent>
    </Card>

    <Card>
      <CardHeader>
        <CardTitle>Access Tokens</CardTitle>
        <CardDescription>Generate tokens for Docker CLI with specific scopes</CardDescription>
      </CardHeader>
      <CardContent className="flex flex-col gap-4">
        <form id="token-form" class="flex flex-col gap-3">
          <div class="flex flex-col gap-1.5">
            <label for="token-name" class="text-xs font-medium text-muted-foreground">Token Name</label>
            <input
              id="token-name"
              name="name"
              type="text"
              placeholder="e.g., CI/CD Pipeline"
              required
              class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50"
            />
          </div>
          
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label for="token-org" class="text-xs font-medium text-muted-foreground">Organization Scope (Optional)</label>
              <select
                id="token-org"
                name="organizationId"
                class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
              >
                <option value="">Global (All Orgs)</option>
                {userOrgs.map(org => (
                  <option value={org.id}>{org.name}</option>
                ))}
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="token-repo" class="text-xs font-medium text-muted-foreground">Repository Scope (Optional)</label>
              <select
                id="token-repo"
                name="repositoryName"
                class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
              >
                <option value="">All Repositories</option>
                {allRepos.map(repo => (
                  <option value={repo.name}>{repo.name}</option>
                ))}
              </select>
            </div>
          </div>

          <Button type="submit" id="generate-token-btn">Generate Token</Button>
        </form>
        <div id="new-token-container" class="hidden flex-col gap-2 p-4 bg-muted rounded-md border border-primary/20">
          <p class="text-sm font-medium">Your new access token:</p>
          <code id="new-token-value" class="text-sm break-all font-mono bg-background p-2 rounded border"></code>
          <p class="text-xs text-muted-foreground">Copy this token now. You won't be able to see it again.</p>
          <div id="push-hint-container" class="hidden flex-col gap-1 pt-1 border-t border-border/50">
            <p class="text-xs font-medium">Push to your namespace:</p>
            <code id="push-command-hint" class="text-xs break-all font-mono bg-background p-2 rounded border"></code>
          </div>
        </div>

        {tokens.length > 0 && (
          <div class="flex flex-col gap-2 mt-2">
            <h3 class="text-sm font-medium text-muted-foreground px-1">Active Tokens</h3>
            {tokens.map((token) => (
              <div class="flex items-center justify-between p-3 border rounded-md bg-card">
                <div class="flex flex-col gap-0.5">
                  <span class="text-sm font-semibold">{token.name}</span>
                  <div class="flex flex-col gap-0.5 text-[10px] text-muted-foreground">
                    <div class="flex items-center gap-2">
                      <code class="bg-muted px-1 rounded text-xs">{token.tokenPreview || "vr_..."}</code>
                      <span>•</span>
                      <span>Expires: {token.expiresAt ? new Date(token.expiresAt).toLocaleDateString() : "Never"}</span>
                    </div>
                    <div class="flex gap-1">
                      {token.organizationId ? (
                        <span class="bg-primary/10 text-primary px-1 rounded">Org: {userOrgs.find(o => o.id === token.organizationId)?.slug || "Unknown"}</span>
                      ) : (
                        <span class="bg-muted px-1 rounded">Global Org</span>
                      )}
                      {token.repositoryName ? (
                        <span class="bg-primary/10 text-primary px-1 rounded">Repo: {token.repositoryName}</span>
                      ) : (
                        <span class="bg-muted px-1 rounded">All Repos</span>
                      )}
                    </div>
                  </div>
                </div>
                <Button
                  type="button"
                  variant="ghost"
                  size="icon"
                  className="text-destructive hover:bg-destructive/10 revoke-token-btn"
                  data-id={token.id}
                  title="Revoke token"
                >
                  <Trash2 className="h-4 w-4" />
                </Button>
              </div>
            ))}
          </div>
        )}
      </CardContent>
    </Card>

    <Card>
      <CardHeader>
        <CardTitle>Docker CLI</CardTitle>
        <CardDescription>Connect to this registry with Docker</CardDescription>
      </CardHeader>
      <CardContent className="flex flex-col gap-2">
        <p class="text-sm text-muted-foreground">Run this command to authenticate your Docker client:</p>
        <code class="rounded-md bg-muted px-3 py-2 font-mono text-sm block">
          docker login {process.env.REGISTRY_PUBLIC_HOST ?? "localhost:5000"}
        </code>
        <p class="text-xs text-muted-foreground">Use your ViceRegistry username and password.</p>
      </CardContent>
    </Card>
  </div>

  <script id="__vr_data" type="application/json" set:html={JSON.stringify({ userOrgs, registryHost: process.env.REGISTRY_PUBLIC_HOST ?? "localhost:5000" })} />

  <script>
    import { toast } from "sonner"
    import { startRegistration } from "@simplewebauthn/browser"

    const __vrDataEl = document.getElementById("__vr_data")
    const __vrData = __vrDataEl ? JSON.parse(__vrDataEl.textContent || "{}") : {}
    const __userOrgs = (__vrData.userOrgs || []) as Array<{ id: string; name: string; slug: string }>
    const __registryHost = (__vrData.registryHost || "localhost:5000") as string

    const form = document.getElementById("settings-form") as HTMLFormElement
    const btn = document.getElementById("save-btn") as HTMLButtonElement
    const passkeyBtn = document.getElementById("register-passkey-btn") as HTMLButtonElement

    passkeyBtn?.addEventListener("click", async () => {
      passkeyBtn.disabled = true
      try {
        const optsRes = await fetch("/api/auth/webauthn/generate-registration-options", {
          credentials: "include",
        })
        if (!optsRes.ok) throw new Error((await optsRes.json()).error || "Failed to get options")
        const options = await optsRes.json()

        const regResp = await startRegistration({ optionsJSON: options })

        const verifyRes = await fetch("/api/auth/webauthn/verify-registration", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify(regResp),
        })

        if (!verifyRes.ok) throw new Error((await verifyRes.json()).error || "Verification failed")
        
        toast.success("Passkey registered successfully")
        setTimeout(() => window.location.reload(), 1000)
      } catch (err: any) {
        toast.error(err.message || "Failed to register passkey")
      } finally {
        passkeyBtn.disabled = false
      }
    })

    const tokenForm = document.getElementById("token-form") as HTMLFormElement
    const tokenBtn = document.getElementById("generate-token-btn") as HTMLButtonElement
    const tokenContainer = document.getElementById("new-token-container") as HTMLDivElement
    const tokenValue = document.getElementById("new-token-value") as HTMLElement

    tokenForm?.addEventListener("submit", async (e) => {
      e.preventDefault()
      tokenBtn.disabled = true
      tokenBtn.textContent = "Generating..."

      const formData = new FormData(tokenForm)
      const name = formData.get("name")
      const organizationId = formData.get("organizationId")
      const repositoryName = formData.get("repositoryName")

      try {
        const res = await fetch("/api/auth/access-tokens", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ name, organizationId, repositoryName }),
        })

        if (!res.ok) throw new Error((await res.json()).error || "Failed to generate token")

        const data = await res.json()
        tokenValue.textContent = data.token
        tokenContainer.classList.remove("hidden")
        tokenContainer.classList.add("flex")

        const orgId = formData.get("organizationId") as string
        const pushContainer = document.getElementById("push-hint-container") as HTMLDivElement
        const pushCmd = document.getElementById("push-command-hint") as HTMLElement
        if (pushContainer && pushCmd && orgId) {
          const org = __userOrgs.find((o) => o.id === orgId)
          if (org) {
            pushCmd.textContent = `docker push ${__registryHost}/${org.slug}/my-image:tag`
            pushContainer.classList.remove("hidden")
            pushContainer.classList.add("flex")
          }
        }

        tokenForm.reset()
        toast.success("Access token generated")
        
        // Reload after a short delay to show the new token in the list
        setTimeout(() => {
          if (confirm("Token generated. Would you like to refresh the list? (The new token will be hidden after refresh)")) {
            window.location.reload()
          }
        }, 5000)
      } catch (err: any) {
        toast.error(err.message || "Failed to generate token")
      } finally {
        tokenBtn.disabled = false
        tokenBtn.textContent = "Generate Token"
      }
    })

    // Revoke token logic
    document.querySelectorAll(".revoke-token-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = (btn as HTMLButtonElement).dataset.id
        if (!id) return

        if (!confirm("Are you sure you want to revoke this token? This action cannot be undone.")) {
          return
        }

        try {
          const res = await fetch(`/api/auth/access-tokens/${encodeURIComponent(id)}`, {
            method: "DELETE",
            credentials: "include",
          })

          if (!res.ok) {
            let msg = "Failed to revoke token"
            try {
              const data = await res.json()
              if (data && typeof data.error === "string") msg = data.error
            } catch {
              /* ignore */
            }
            throw new Error(msg)
          }

          toast.success("Token revoked")
          setTimeout(() => window.location.reload(), 1000)
        } catch (err: any) {
          toast.error(err.message || "Failed to revoke token")
        }
      })
    })

    // Remove passkey
    document.querySelectorAll(".revoke-passkey-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const credentialId = (btn as HTMLButtonElement).dataset.credentialId
        if (!credentialId) return

        if (!confirm("Remove this passkey? You can register a new one later.")) {
          return
        }

        try {
          const res = await fetch(
            `/api/auth/webauthn/credentials/${encodeURIComponent(credentialId)}`,
            { method: "DELETE", credentials: "include" },
          )

          if (!res.ok) {
            let msg = "Failed to remove passkey"
            try {
              const data = await res.json()
              if (data && typeof data.error === "string") msg = data.error
            } catch {
              /* ignore */
            }
            throw new Error(msg)
          }

          toast.success("Passkey removed")
          setTimeout(() => window.location.reload(), 1000)
        } catch (err: any) {
          toast.error(err.message || "Failed to remove passkey")
        }
      })
    })

    form?.addEventListener("submit", async (e) => {
      e.preventDefault()
      btn.disabled = true
      btn.textContent = "Saving..."

      const formData = new FormData(form)
      const data: Record<string, string> = {}
      formData.forEach((value, key) => {
        if (value) data[key] = value.toString()
      })

      try {
        const res = await fetch("/api/auth/settings", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify(data),
        })

        if (!res.ok) {
          const err = await res.json()
          throw new Error(err.error || "Failed to update settings")
        }

        toast.success("Settings updated successfully")
        form.reset()
        // restore email
        const emailInput = document.getElementById("email") as HTMLInputElement
        if (data.email) emailInput.value = data.email
      } catch (err: any) {
        toast.error(err.message)
      } finally {
        btn.disabled = false
        btn.textContent = "Save Changes"
      }
    })
  </script>
</AppLayout>
