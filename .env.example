# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://viceregistry:secret@localhost:5432/viceregistry

# ── Session (generate with: openssl rand -hex 32) ────────────────────────────
SESSION_SECRET=replace_with_64_hex_chars

# ── Registry token auth (generate with: npm run keys:generate) ────────────────
REGISTRY_TOKEN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_KEY_HERE\n-----END PRIVATE KEY-----"
REGISTRY_TOKEN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPASTE_KEY_HERE\n-----END PUBLIC KEY-----"
REGISTRY_TOKEN_ISSUER=viceregistry

# ── Docker Registry ───────────────────────────────────────────────────────────
# Internal URL (container-to-container in compose, or http://localhost:5000 locally)
REGISTRY_URL=http://registry:5000
# Public hostname shown in pull command snippets in the UI
REGISTRY_PUBLIC_HOST=registry.example.com

# ── S3 / Object Storage ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET=viceregistry-blobs
# Set for MinIO or non-AWS S3; leave blank for native AWS
S3_ENDPOINT_URL=

# ── Admin seed ────────────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

# ── App ───────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=4321
PUBLIC_URL=https://registry.example.com
